// Pamaina — core data model
//
// Multi-tenancy model: `Company` is the tenant root. Every tenant-scoped
// table carries a `companyId` foreign key so a single Postgres database can
// serve thousands of companies with row-level isolation enforced in the
// repository layer (every query is filtered by companyId).
//
// Schedule / shift-instance tables are intentionally NOT modeled yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Tenant
// ─────────────────────────────────────────────────────────────────────────

model Company {
  id        String    @id @default(uuid())
  name      String
  /// URL/slug-safe unique identifier, e.g. used for tenant-aware routing.
  slug      String    @unique
  /// Lithuanian company registration code (Juridinio asmens kodas).
  legalCode String?   @unique @map("legal_code")
  /// Lithuanian VAT code (PVM mokėtojo kodas).
  vatCode   String?   @map("vat_code")
  email     String
  phone     String?
  address   String?
  city      String?
  country   String    @default("LT")
  timezone  String    @default("Europe/Vilnius")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  roles                 Role[]
  users                 User[]
  departments           Department[]
  positions             Position[]
  employees             Employee[]
  schedules             Schedule[]
  shiftTemplates        ShiftTemplate[]
  absenceTypes          AbsenceType[]
  companyNonWorkingDays CompanyNonWorkingDay[]
  employeeRequests      EmployeeRequest[]
  notifications         Notification[]
  requestAuditLogs      RequestAuditLog[]
  settings              CompanySettings?

  @@index([isActive])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────
// Company onboarding / settings
// ─────────────────────────────────────────────────────────────────────────

/// Industry the company operates in, selected during onboarding. Purely
/// informational at this stage — does not yet drive any scheduling logic.
enum BusinessType {
  FACTORY
  RESTAURANT
  RETAIL
  WAREHOUSE
  LOGISTICS
  OFFICE
  OTHER
}

/// How the company organizes its working week. Stored as a company-level
/// default; per-employee overrides are out of scope until scheduling ships.
enum WorkWeekType {
  FIVE_DAY
  SIX_DAY
  /// "Suminė darbo laiko apskaita" — aggregated/summarized working time
  /// accounting, common for shift-based Lithuanian workplaces.
  SUMMARIZED
}

/// Which vacation accrual model the company uses. Only the selection is
/// stored for now — accrual calculations are a future prompt.
enum VacationPolicyType {
  ANNUAL_ALLOCATION
  MONTHLY_ACCRUAL
}

model CompanySettings {
  id        String @id @default(uuid())
  companyId String @unique @map("company_id")

  logoUrl            String? @map("logo_url")
  preferredLanguage  String  @default("lt") @map("preferred_language")
  /// Company-wide default annual vacation entitlement per employee, in days.
  /// Deliberately a single flat number for now (no per-employee overrides,
  /// no accrual schedule) — see VacationPolicyType's own comment for why a
  /// full accrual engine is out of scope until a real HR policy is defined.
  annualVacationDays Int     @default(20) @map("annual_vacation_days")

  businessType   BusinessType?       @map("business_type")
  workWeekType   WorkWeekType?       @map("work_week_type")
  vacationPolicy VacationPolicyType? @map("vacation_policy")

  /// Set once the onboarding wizard is completed; null while a company is
  /// still onboarding. Used by the frontend to gate access to the app.
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// ─────────────────────────────────────────────────────────────────────────
// Auth / RBAC
// ─────────────────────────────────────────────────────────────────────────

/// Fixed platform role keys. Stored as data (Role.key) rather than a native
/// Postgres enum so companies can add custom roles later without a schema
/// migration; this enum only pins the type-safe set of *system* roles that
/// ship out of the box and are seeded for every new company.
enum SystemRoleKey {
  SUPER_ADMIN
  COMPANY_OWNER
  MANAGER
  EMPLOYEE
}

model Permission {
  id          String   @id @default(uuid())
  /// Dot-notation permission key, e.g. "employee.create".
  key         String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id          String   @id @default(uuid())
  /// Null for global system roles (templates); set for a company-defined
  /// custom role scoped to that company.
  companyId   String?  @map("company_id")
  name        String
  /// Stable key used by application code for authorization checks.
  /// One of SystemRoleKey for seeded roles, or a free-form slug for
  /// company-defined custom roles.
  key         String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([companyId, key])
  @@index([companyId])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                 String    @id @default(uuid())
  /// Null only for platform-level Super Admin accounts.
  companyId          String?   @map("company_id")
  roleId             String    @map("role_id")
  email              String    @unique
  passwordHash       String    @map("password_hash")
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  phone              String?
  isActive           Boolean   @default(true) @map("is_active")
  /// True right after an account is created with a system-generated
  /// temporary password (see Employee auto-provisioning) until the user
  /// completes the forced change-password step on first login.
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  company            Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role               Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)
  employee           Employee?
  refreshTokens      RefreshToken[]
  createdSchedules   Schedule[]           @relation("ScheduleCreatedBy")
  updatedSchedules   Schedule[]           @relation("ScheduleUpdatedBy")
  updatedAssignments ScheduleAssignment[] @relation("AssignmentUpdatedBy")
  reviewedRequests   EmployeeRequest[]    @relation("RequestReviewedBy")
  notifications      Notification[]
  requestAuditLogs   RequestAuditLog[]    @relation("RequestAuditPerformedBy")

  @@index([companyId])
  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  /// SHA-256 hash of the refresh token — the raw token is never persisted.
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  /// Carried forward across rotations so a "Remember me" choice made at
  /// login still applies to the cookie set by later silent refreshes.
  rememberMe  Boolean   @default(false) @map("remember_me")
  revokedAt   DateTime? @map("revoked_at")
  replacedBy  String?   @map("replaced_by")
  createdByIp String?   @map("created_by_ip")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// Organization structure
// ─────────────────────────────────────────────────────────────────────────

model Department {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  description String?
  /// Hex color used as a visual indicator in the UI (e.g. "#2563EB").
  color       String    @default("#2563EB")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  positions Position[]
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("departments")
}

model Position {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  departmentId String?   @map("department_id")
  title        String
  description  String?
  /// Hex color used as a visual indicator in the UI (e.g. "#2563EB").
  color        String    @default("#2563EB")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@unique([companyId, title])
  @@index([companyId])
  @@index([departmentId])
  @@map("positions")
}

// ─────────────────────────────────────────────────────────────────────────
// People
// ─────────────────────────────────────────────────────────────────────────

/// Record lifecycle status for the Employee Management module — this is
/// about the PERSON record, not their employment. ARCHIVED is only reached
/// via the dedicated archive endpoint and is the module's soft-delete
/// state; records are never hard-deleted.
enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

/// How much of a full-time schedule an employee works. Feeds the Lithuanian
/// Working Time Engine's monthly-required-hours calculation (see
/// modules/working-time) as a multiplier against the standard monthly norm —
/// PAMAINA is scheduling software, not an HR/payroll system, so this is
/// deliberately a fixed set of fractions rather than a free-form FTE field.
enum EmploymentType {
  FULL_TIME
  PART_TIME_75
  PART_TIME_50
  PART_TIME_25
}

/// Employees are the single source of truth for scheduling — no separate
/// Employment Contract entity. Department/position/employment type live
/// directly on the employee record.
model Employee {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  /// Optional link to a login-capable User. Not every employee record
  /// needs platform access (e.g. added ahead of onboarding).
  userId    String? @unique @map("user_id")

  /// Company-scoped personnel number (e.g. "EMP-0042").
  employeeCode   String         @map("employee_code")
  firstName      String         @map("first_name")
  lastName       String         @map("last_name")
  email          String?
  phone          String?
  departmentId   String?        @map("department_id")
  positionId     String?        @map("position_id")
  employmentType EmploymentType @default(FULL_TIME) @map("employment_type")

  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  notes     String?

  /// Record lifecycle: ACTIVE/INACTIVE are editable directly; ARCHIVED is
  /// only set by the archive endpoint, in lockstep with deletedAt/isActive.
  status    EmployeeStatus @default(ACTIVE)
  isActive  Boolean        @default(true) @map("is_active")
  deletedAt DateTime?      @map("deleted_at")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  department          Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position            Position?            @relation(fields: [positionId], references: [id], onDelete: SetNull)
  scheduleAssignments ScheduleAssignment[]
  requests            EmployeeRequest[]

  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([companyId, status])
  @@index([departmentId])
  @@index([positionId])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────────────────
// Absence types — exactly four standard Lithuanian non-working entries per
// company (P/A/M/L, see AbsenceTypeService.DEFAULT_ABSENCE_TYPES). Custom
// types are not supported; code/name are fixed, managers may only edit
// color/description/active. Mutually exclusive with ShiftTemplate on a
// ScheduleAssignment.
// ─────────────────────────────────────────────────────────────────────────

model AbsenceType {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  /// Fixed short code shown in the scheduler grid (e.g. "P"). Immutable.
  code        String
  /// Fixed full display name (e.g. "Poilsio diena"). Immutable.
  name        String
  /// Hex color used for the cell background (e.g. "#F59E0B").
  color       String  @default("#F59E0B")
  /// Optional manager-facing note — the only free-text field managers may edit.
  description String?
  /// True for the four seeded standard types. Legacy rows predating this
  /// model (kept only so historical assignments/requests still resolve)
  /// are false and hidden from every UI list.
  isDefault   Boolean @default(true) @map("is_default")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments ScheduleAssignment[]
  requests    EmployeeRequest[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
  @@map("absence_types")
}

// ─────────────────────────────────────────────────────────────────────────
// Monthly scheduler — the core scheduling feature. ScheduleAssignment is
// intentionally a plain (employee, date, shiftTemplate) fact table so future
// features (working-hour engine, rest-period validation, warnings, overtime)
// can layer their own read-side logic on top without changing this shape.
//
// Schedules may be edited even after publishing (managers must never be
// forced to create a new schedule) — updatedBy/updatedAt track who last
// touched a schedule (directly, or via one of its assignments) as a simple
// audit trail; a full version history can be layered on top later without
// changing this shape.
// ─────────────────────────────────────────────────────────────────────────

enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

model Schedule {
  id        String         @id @default(uuid())
  companyId String         @map("company_id")
  year      Int
  month     Int
  status    ScheduleStatus @default(DRAFT)
  createdBy String         @map("created_by")
  updatedBy String?        @map("updated_by")

  publishedAt DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator     User                 @relation("ScheduleCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  updater     User?                @relation("ScheduleUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  assignments ScheduleAssignment[]

  @@unique([companyId, year, month])
  @@index([companyId])
  @@index([companyId, status])
  @@map("schedules")
}

/// Company-defined shift definitions (e.g. "Morning 06:00-14:00"). Replaces
/// the earlier fixed ShiftType enum so every company can define its own set.
/// Archiving (active=false) never deletes historical ScheduleAssignments —
/// past schedules keep showing the archived template's name/hours/color.
model ShiftTemplate {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  name      String
  /// Short 1-3 char code shown inside compact grid cells (e.g. "M", "EV").
  shortCode String @map("short_code")
  /// Hex color used for the cell background (e.g. "#2563EB").
  color     String @default("#2563EB")

  /// 24h "HH:MM" time-of-day. Overnight shifts (e.g. 22:00-06:00) are valid;
  /// duration is computed by wrapping past midnight.
  startTime    String @map("start_time")
  endTime      String @map("end_time")
  breakMinutes Int    @default(0) @map("break_minutes")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments ScheduleAssignment[]

  @@unique([companyId, name])
  @@unique([companyId, shortCode])
  @@index([companyId])
  @@index([companyId, active])
  @@map("shift_templates")
}

/// Exactly one of shiftTemplateId/absenceTypeId is set — never both, never
/// neither. Enforced by a DB check constraint (see migration) plus DTO
/// validation, since Prisma has no declarative XOR constraint.
model ScheduleAssignment {
  id              String  @id @default(uuid())
  scheduleId      String  @map("schedule_id")
  employeeId      String  @map("employee_id")
  shiftTemplateId String? @map("shift_template_id")
  absenceTypeId   String? @map("absence_type_id")
  /// Who last created/edited this specific shift — the seed of a future
  /// per-cell version history.
  updatedBy       String? @map("updated_by")
  /// Set when this row was auto-created/overwritten by an approved
  /// EmployeeRequest — lets a later revocation find exactly which rows to
  /// delete or restore, without guessing. Null for manually-managed shifts.
  sourceRequestId String? @map("source_request_id")

  date  DateTime @db.Date
  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schedule      Schedule         @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  updater       User?            @relation("AssignmentUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  shiftTemplate ShiftTemplate?   @relation(fields: [shiftTemplateId], references: [id], onDelete: Restrict)
  absenceType   AbsenceType?     @relation(fields: [absenceTypeId], references: [id], onDelete: Restrict)
  sourceRequest EmployeeRequest? @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)

  @@unique([scheduleId, employeeId, date])
  @@index([scheduleId])
  @@index([employeeId])
  @@index([scheduleId, date])
  @@index([shiftTemplateId])
  @@index([absenceTypeId])
  @@index([sourceRequestId])
  @@map("schedule_assignments")
}

// ─────────────────────────────────────────────────────────────────────────
// Lithuanian Working Time Engine — official public holidays are computed
// in code (apps/backend/src/modules/working-time/lithuanian-holidays.ts),
// not stored, since they're a pure function of the year. Only company-
// specific additions (e.g. a local factory shutdown day) are persisted.
// ─────────────────────────────────────────────────────────────────────────

model CompanyNonWorkingDay {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  date DateTime @db.Date
  name String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([companyId])
  @@map("company_non_working_days")
}

// ─────────────────────────────────────────────────────────────────────────
// Employee self-service requests (vacation, sick leave, day off, ...) — the
// "type" reuses the company's own AbsenceType list rather than a parallel
// enum, since AbsenceType already models exactly this (including letting a
// manager add a custom one beyond the seeded defaults).
// ─────────────────────────────────────────────────────────────────────────

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  /// Withdrawn by the employee themselves, only reachable while PENDING.
  CANCELLED
  /// Was APPROVED (and synced into the Scheduler), then a manager reversed
  /// that decision — kept distinct from REJECTED ("never approved") so the
  /// audit trail and UI can say what actually happened.
  REVOKED
}

model EmployeeRequest {
  id            String        @id @default(uuid())
  companyId     String        @map("company_id")
  employeeId    String        @map("employee_id")
  absenceTypeId String        @map("absence_type_id")
  startDate     DateTime      @map("start_date") @db.Date
  endDate       DateTime      @map("end_date") @db.Date
  comment       String?
  status        RequestStatus @default(PENDING)

  reviewedBy    String?   @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewComment String?   @map("review_comment")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  absenceType         AbsenceType          @relation(fields: [absenceTypeId], references: [id], onDelete: Restrict)
  reviewer            User?                @relation("RequestReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  scheduleAssignments ScheduleAssignment[]
  auditLogs           RequestAuditLog[]

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, status])
  @@map("employee_requests")
}

// ─────────────────────────────────────────────────────────────────────────
// Audit trail for the leave-approval <-> Scheduler sync. `details` stores
// exactly what's needed to reverse an approval: which dates got a brand-new
// absence row (delete on revoke) vs. which overwrote an existing shift
// (restore the previous shiftTemplateId/notes on revoke). See
// request-schedule-sync.service.ts for the shape written/read here.
// ─────────────────────────────────────────────────────────────────────────

enum AuditAction {
  REQUEST_APPROVED
  REQUEST_APPROVAL_REVOKED
}

model RequestAuditLog {
  id          String      @id @default(uuid())
  companyId   String      @map("company_id")
  requestId   String      @map("request_id")
  action      AuditAction
  performedBy String      @map("performed_by")
  details     Json?
  createdAt   DateTime    @default(now()) @map("created_at")

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  request   EmployeeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  performer User            @relation("RequestAuditPerformedBy", fields: [performedBy], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([requestId])
  @@map("request_audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// In-app notifications only (no push/email yet). Owned by User rather than
// Employee since Managers/Owners receive them too (e.g. a new request).
// ─────────────────────────────────────────────────────────────────────────

enum NotificationType {
  SCHEDULE_PUBLISHED
  REQUEST_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
  SHIFT_ASSIGNED
  SHIFT_UPDATED
}

model Notification {
  id        String           @id @default(uuid())
  companyId String           @map("company_id")
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  /// Relative app path the notification should link to, e.g. "/my-requests".
  link      String?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId, readAt])
  @@map("notifications")
}
