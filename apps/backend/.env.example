# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://pamaina:pamaina@localhost:5432/pamaina?schema=public"

# ── Auth / JWT ────────────────────────────────────────────────────────────
# Use long random secrets in production (openssl rand -base64 64).
JWT_ACCESS_SECRET=change-me-access-secret-change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret-change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Security ──────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
