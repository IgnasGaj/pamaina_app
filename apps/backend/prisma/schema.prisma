// Pamaina — core data model
//
// Multi-tenancy model: `Company` is the tenant root. Every tenant-scoped
// table carries a `companyId` foreign key so a single Postgres database can
// serve thousands of companies with row-level isolation enforced in the
// repository layer (every query is filtered by companyId).
//
// Schedule / shift-instance tables are intentionally NOT modeled yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Tenant
// ─────────────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  /// URL/slug-safe unique identifier, e.g. used for tenant-aware routing.
  slug      String   @unique
  /// Lithuanian company registration code (Juridinio asmens kodas).
  legalCode String?  @unique @map("legal_code")
  /// Lithuanian VAT code (PVM mokėtojo kodas).
  vatCode   String?  @map("vat_code")
  email     String
  phone     String?
  address   String?
  city      String?
  country   String   @default("LT")
  timezone  String   @default("Europe/Vilnius")
  isActive  Boolean  @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles               Role[]
  users               User[]
  departments         Department[]
  positions           Position[]
  employees           Employee[]
  employmentContracts EmploymentContract[]
  settings            CompanySettings?

  @@index([isActive])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────
// Company onboarding / settings
// ─────────────────────────────────────────────────────────────────────────

/// Industry the company operates in, selected during onboarding. Purely
/// informational at this stage — does not yet drive any scheduling logic.
enum BusinessType {
  FACTORY
  RESTAURANT
  RETAIL
  WAREHOUSE
  LOGISTICS
  OFFICE
  OTHER
}

/// How the company organizes its working week. Stored as a company-level
/// default; per-employee overrides are out of scope until scheduling ships.
enum WorkWeekType {
  FIVE_DAY
  SIX_DAY
  /// "Suminė darbo laiko apskaita" — aggregated/summarized working time
  /// accounting, common for shift-based Lithuanian workplaces.
  SUMMARIZED
}

/// Which vacation accrual model the company uses. Only the selection is
/// stored for now — accrual calculations are a future prompt.
enum VacationPolicyType {
  ANNUAL_ALLOCATION
  MONTHLY_ACCRUAL
}

model CompanySettings {
  id        String @id @default(uuid())
  companyId String @unique @map("company_id")

  logoUrl           String? @map("logo_url")
  preferredLanguage String  @default("lt") @map("preferred_language")

  businessType   BusinessType?       @map("business_type")
  workWeekType   WorkWeekType?       @map("work_week_type")
  vacationPolicy VacationPolicyType? @map("vacation_policy")

  /// Set once the onboarding wizard is completed; null while a company is
  /// still onboarding. Used by the frontend to gate access to the app.
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// ─────────────────────────────────────────────────────────────────────────
// Auth / RBAC
// ─────────────────────────────────────────────────────────────────────────

/// Fixed platform role keys. Stored as data (Role.key) rather than a native
/// Postgres enum so companies can add custom roles later without a schema
/// migration; this enum only pins the type-safe set of *system* roles that
/// ship out of the box and are seeded for every new company.
enum SystemRoleKey {
  SUPER_ADMIN
  COMPANY_OWNER
  MANAGER
  EMPLOYEE
}

model Permission {
  id          String   @id @default(uuid())
  /// Dot-notation permission key, e.g. "employee.create".
  key         String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id        String   @id @default(uuid())
  /// Null for global system roles (templates); set for a company-defined
  /// custom role scoped to that company.
  companyId String?  @map("company_id")
  name      String
  /// Stable key used by application code for authorization checks.
  /// One of SystemRoleKey for seeded roles, or a free-form slug for
  /// company-defined custom roles.
  key         String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([companyId, key])
  @@index([companyId])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String    @id @default(uuid())
  /// Null only for platform-level Super Admin accounts.
  companyId    String?   @map("company_id")
  roleId       String    @map("role_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company       Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  employee      Employee?
  refreshTokens RefreshToken[]

  @@index([companyId])
  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  /// SHA-256 hash of the refresh token — the raw token is never persisted.
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  /// Carried forward across rotations so a "Remember me" choice made at
  /// login still applies to the cookie set by later silent refreshes.
  rememberMe   Boolean   @default(false) @map("remember_me")
  revokedAt    DateTime? @map("revoked_at")
  replacedBy   String?   @map("replaced_by")
  createdByIp  String?   @map("created_by_ip")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// Organization structure
// ─────────────────────────────────────────────────────────────────────────

model Department {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  description String?
  /// Hex color used as a visual indicator in the UI (e.g. "#2563EB").
  color       String    @default("#2563EB")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  positions           Position[]
  employmentContracts EmploymentContract[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("departments")
}

model Position {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  departmentId String?   @map("department_id")
  title        String
  description  String?
  /// Hex color used as a visual indicator in the UI (e.g. "#2563EB").
  color        String    @default("#2563EB")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department          Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employmentContracts EmploymentContract[]

  @@unique([companyId, title])
  @@index([companyId])
  @@index([departmentId])
  @@map("positions")
}

// ─────────────────────────────────────────────────────────────────────────
// People
// ─────────────────────────────────────────────────────────────────────────

/// Record lifecycle status for the Employee Management module — this is
/// about the PERSON record, not their employment. ARCHIVED is only reached
/// via the dedicated archive endpoint and is the module's soft-delete
/// state; records are never hard-deleted.
enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

/// Employees represent PEOPLE. All employment-specific information (which
/// department/position, hours, contract dates, ...) lives on
/// EmploymentContract instead, since a person can have multiple contracts
/// over time and scheduling/vacations must key off the contract, not the
/// person record.
model Employee {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  /// Optional link to a login-capable User. Not every employee record
  /// needs platform access (e.g. added ahead of onboarding).
  userId    String? @unique @map("user_id")

  /// Company-scoped personnel number (e.g. "EMP-0042").
  employeeCode String  @map("employee_code")
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  email        String?
  phone        String?
  /// National personal identification code (e.g. Lithuanian asmens kodas).
  personalCode String? @map("personal_code")
  birthDate    DateTime? @map("birth_date") @db.Date

  /// Record lifecycle: ACTIVE/INACTIVE are editable directly; ARCHIVED is
  /// only set by the archive endpoint, in lockstep with deletedAt/isActive.
  status    EmployeeStatus @default(ACTIVE)
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  employmentContracts EmploymentContract[]

  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([companyId, status])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────────────────
// Employment contracts — the single source of truth for scheduling,
// vacation calculations, monthly required hours, and (future) payroll.
// ─────────────────────────────────────────────────────────────────────────

enum ContractStatus {
  ACTIVE
  ENDED
  SUSPENDED
  DRAFT
}

enum ContractType {
  PERMANENT
  FIXED_TERM
  SEASONAL
  TEMPORARY
  INTERNSHIP
}

enum WorkWeek {
  FIVE_DAY
  SIX_DAY
  CUSTOM
}

model EmploymentContract {
  id           String  @id @default(uuid())
  companyId    String  @map("company_id")
  employeeId   String  @map("employee_id")
  departmentId String? @map("department_id")
  positionId   String? @map("position_id")

  /// Company-scoped contract number (e.g. "CTR-0042").
  contractNumber String         @map("contract_number")
  status         ContractStatus @default(ACTIVE)
  contractType   ContractType   @map("contract_type")

  startDate         DateTime  @map("start_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  probationEndDate  DateTime? @map("probation_end_date") @db.Date

  weeklyHours Decimal  @default(40) @map("weekly_hours") @db.Decimal(5, 2)
  dailyHours  Decimal  @default(8) @map("daily_hours") @db.Decimal(4, 2)
  /// Full-time equivalent, 0.1–1.0.
  fte         Decimal  @default(1.0) @db.Decimal(3, 2)
  workWeek    WorkWeek @default(FIVE_DAY) @map("work_week")

  vacationDaysPerYear   Int     @default(20) @map("vacation_days_per_year")
  /// "Suminė darbo laiko apskaita" — aggregated/summarized working time
  /// accounting, common for shift-based Lithuanian workplaces.
  summarizedWorkingTime Boolean @default(false) @map("summarized_working_time")

  canWorkWeekends Boolean @default(true) @map("can_work_weekends")
  canWorkHolidays Boolean @default(false) @map("can_work_holidays")
  canWorkNights   Boolean @default(true) @map("can_work_nights")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position   Position?   @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@unique([companyId, contractNumber])
  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, employeeId, status])
  @@index([departmentId])
  @@index([positionId])
  @@map("employment_contracts")
}
