// Pamaina — core data model
//
// Multi-tenancy model: `Company` is the tenant root. Every tenant-scoped
// table carries a `companyId` foreign key so a single Postgres database can
// serve thousands of companies with row-level isolation enforced in the
// repository layer (every query is filtered by companyId).
//
// Schedule / shift-instance tables are intentionally NOT modeled yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Tenant
// ─────────────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  /// URL/slug-safe unique identifier, e.g. used for tenant-aware routing.
  slug      String   @unique
  /// Lithuanian company registration code (Juridinio asmens kodas).
  legalCode String?  @map("legal_code")
  /// Lithuanian VAT code (PVM mokėtojo kodas).
  vatCode   String?  @map("vat_code")
  email     String
  phone     String?
  address   String?
  city      String?
  country   String   @default("LT")
  timezone  String   @default("Europe/Vilnius")
  isActive  Boolean  @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles       Role[]
  users       User[]
  departments Department[]
  positions   Position[]
  employees   Employee[]

  @@index([isActive])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────
// Auth / RBAC
// ─────────────────────────────────────────────────────────────────────────

/// Fixed platform role keys. Stored as data (Role.key) rather than a native
/// Postgres enum so companies can add custom roles later without a schema
/// migration; this enum only pins the type-safe set of *system* roles that
/// ship out of the box and are seeded for every new company.
enum SystemRoleKey {
  SUPER_ADMIN
  COMPANY_OWNER
  MANAGER
  EMPLOYEE
}

model Permission {
  id          String   @id @default(uuid())
  /// Dot-notation permission key, e.g. "employee.create".
  key         String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id        String   @id @default(uuid())
  /// Null for global system roles (templates); set for a company-defined
  /// custom role scoped to that company.
  companyId String?  @map("company_id")
  name      String
  /// Stable key used by application code for authorization checks.
  /// One of SystemRoleKey for seeded roles, or a free-form slug for
  /// company-defined custom roles.
  key         String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([companyId, key])
  @@index([companyId])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String    @id @default(uuid())
  /// Null only for platform-level Super Admin accounts.
  companyId    String?   @map("company_id")
  roleId       String    @map("role_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company       Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  employee      Employee?
  refreshTokens RefreshToken[]

  @@index([companyId])
  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  /// SHA-256 hash of the refresh token — the raw token is never persisted.
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedBy   String?   @map("replaced_by")
  createdByIp  String?   @map("created_by_ip")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────
// Organization structure
// ─────────────────────────────────────────────────────────────────────────

model Department {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  positions Position[]
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("departments")
}

model Position {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  departmentId String?   @map("department_id")
  title        String
  description  String?
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@unique([companyId, title])
  @@index([companyId])
  @@index([departmentId])
  @@map("positions")
}

// ─────────────────────────────────────────────────────────────────────────
// People
// ─────────────────────────────────────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  SEASONAL
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

model Employee {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  /// Optional link to a login-capable User. Not every employee record
  /// needs platform access (e.g. added ahead of onboarding).
  userId    String? @unique @map("user_id")

  departmentId String? @map("department_id")
  positionId   String? @map("position_id")

  /// Company-scoped personnel number (e.g. "EMP-0042").
  employeeCode String  @map("employee_code")
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  email        String?
  phone        String?

  employmentType   EmploymentType   @default(FULL_TIME) @map("employment_type")
  employmentStatus EmploymentStatus @default(ACTIVE) @map("employment_status")
  /// Contracted hours per week, used by working-hours calculations.
  contractedWeeklyHours Decimal @default(40) @map("contracted_weekly_hours") @db.Decimal(5, 2)

  hireDate        DateTime  @map("hire_date") @db.Date
  terminationDate DateTime? @map("termination_date") @db.Date

  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position   Position?   @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([departmentId])
  @@index([positionId])
  @@map("employees")
}
